# Runtime mode
APP_ENV=development
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000

# Generate independent values, for example with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES=3600

# Local SQLite is suitable for development. Use managed persistent storage in production.
DATABASE_URL=sqlite:///ai_agent_system.db

# Comma-separated allowed frontend origins. Wildcards are rejected.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Registration is disabled by default. Public registration can create team accounts only.
ALLOW_PUBLIC_REGISTRATION=false
REGISTRATION_MIN_PASSWORD_LENGTH=12
MAX_CONTENT_LENGTH=1048576

# Optional AI provider configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
